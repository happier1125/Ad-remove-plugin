# > MiniBili 跳转 (含直播)
# @author Liano

[rewrite_local]
# 1. 视频跳转
^https?://(?:www\.|m\.)?bilibili\.com/video/(BV[A-Za-z0-9]+|av[0-9]+) url 302 minibili://video/$1

# 2. 搜索跳转
^https?://search\.bilibili\.com/([^?]+)\?.*[?&]keyword=([^&]+) url 302 minibili://search?keyword=$2&type=$1

# 3. 直播间跳转
^https?://live\.bilibili\.com/(?:h5/)?([0-9]+) url 302 minibili://live/$1

[mitm]
hostname = *.bilibili.com
