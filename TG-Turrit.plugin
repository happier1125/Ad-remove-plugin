#!name=Turrit 外链跳转
#!desc=点击 t.me 外部链接时，自动跳转至 Turrit App 打开
#!author=Liano
#!icon=https://raw.githubusercontent.com/happier1125/Ad-remove-plugin/main/Turrit.PNG
#!openUrl=https://apps.apple.com/app/id6471781238

[Rewrite]
^https?:\/\/(www\.)?t\.me\/(.+)$ turrit://resolve?domain=$2 302

[MITM]
hostname = t.me, www.t.me
